# ── L1 Identity & Context — Environment ──

L1_DEBUG=true
L1_MOCK_IDP_ENABLED=true

# ── Neo4j AuraDB ──
# Note: You need a Neo4j instance to run the role resolution logic.
L1_NEO4J_URI=neo4j+s://<YOUR_INSTANCE_ID>.databases.neo4j.io
L1_NEO4J_USERNAME=neo4j
L1_NEO4J_PASSWORD=<YOUR_PASSWORD>
L1_NEO4J_DATABASE=neo4j

# ── Application Settings ──
L1_REDIS_URL=redis://apollo-l1-redis:6379/0
L1_HMAC_SECRET_KEY=generate-a-secure-random-secret-here
